{
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Bash(gh:*)",
      "Bash(git:*)",
      "Read",
      "Write",
      "Edit",
      "Agent",
      "TaskStop",
      "AskUserQuestion"
    ],
    "deny": [
      "Bash(gh pr merge:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push --force-with-lease:*)"
    ]
  }
}
