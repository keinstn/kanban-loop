{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/<owner>/kanban-loop/schemas/state.schema.json",
  "title": "kanban-loop state",
  "type": "object",
  "additionalProperties": false,
  "required": ["date", "dispatchedToday", "issues"],
  "properties": {
    "date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "Local date of the current daily window (YYYY-MM-DD)."
    },
    "dispatchedToday": {
      "type": "integer",
      "minimum": 0,
      "description": "Dispatches issued during the current date window."
    },
    "issues": {
      "type": "object",
      "description": "Keyed by '<owner/repo>#<num>'.",
      "propertyNames": { "pattern": "^[^/]+/[^#]+#\\d+$" },
      "additionalProperties": { "$ref": "#/$defs/issueState" }
    }
  },
  "$defs": {
    "issueState": {
      "type": "object",
      "additionalProperties": false,
      "required": ["phase", "pr", "reviewRounds", "subagent", "workspace", "updatedAt"],
      "properties": {
        "phase": {
          "type": "string",
          "enum": ["implementing", "reviewing", "escalated", "idle"]
        },
        "pr": { "type": ["integer", "null"], "minimum": 1 },
        "reviewRounds": { "type": "integer", "minimum": 0 },
        "subagent": { "type": ["string", "null"], "enum": ["running", null] },
        "subagentId": {
          "type": ["string", "null"],
          "description": "Background task id of the running subagent, for TaskStop by the watchdog. Null when idle."
        },
        "dispatchedAt": {
          "type": ["string", "null"],
          "format": "date-time",
          "description": "When the current subagent was dispatched; basis for the stall timeout. Null when idle."
        },
        "attempts": {
          "type": "integer",
          "minimum": 0,
          "description": "Consecutive dispatches for the current work unit (stall retries + model escalation); resets to 0 when the issue advances to a new column."
        },
        "model": {
          "type": ["string", "null"],
          "description": "Model of the current/last dispatch (e.g. 'sonnet', 'opus'). Encodes the implementer escalation rung. Null when idle."
        },
        "workspace": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    }
  }
}
